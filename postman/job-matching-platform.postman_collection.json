{
  "info": {
    "name": "Job Matching Platform API",
    "_postman_id": "2f6b5c48-2caa-4d1e-b4a0-5b47fd6f0c3b",
    "description": "Postman collection to test auth + application routes for the Job Matching Platform.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Worker) -> sets workerToken",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{workerEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const token = json?.data?.token;",
                  "if (token) pm.environment.set('workerToken', token);",
                  "const userId = json?.data?.user?.id;",
                  "if (userId) pm.environment.set('workerId', userId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (Client) -> sets clientToken",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{clientEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const token = json?.data?.token;",
                  "if (token) pm.environment.set('clientToken', token);",
                  "const userId = json?.data?.user?.id;",
                  "if (userId) pm.environment.set('clientId', userId);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Jobs (helper)",
      "item": [
        {
          "name": "List Jobs -> sets jobId (first result)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/jobs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const jobId = json?.data?.data?.[0]?.id;",
                  "if (jobId) pm.environment.set('jobId', jobId);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Apply For Job (Worker) -> sets applicationId",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{workerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobId\": \"{{jobId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/applications",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const applicationId = json?.data?.id;",
                  "if (applicationId) pm.environment.set('applicationId', applicationId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Applications (Worker)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{workerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/applications/my",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications", "my"]
            }
          }
        },
        {
          "name": "Get Job Applications (Client)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{clientToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/applications/job/{{jobId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications", "job", "{{jobId}}"]
            }
          }
        },
        {
          "name": "Update Application Status (Client)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{clientToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"MATCHED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/applications/{{applicationId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications", "{{applicationId}}", "status"]
            }
          }
        }
      ]
    }
  ]
}
